# ==========================================
# 1. DEPENDÊNCIAS E PACOTES
# ==========================================
# Ignora todas as pastas node_modules do projeto (raiz e subpastas)
node_modules/
/.pnp
.pnp.js

# ==========================================
# 2. ARQUIVOS DE AMBIENTE E SEGREDOS (CRÍTICO)
# ==========================================
# Nunca suba chaves de API, senhas de banco ou segredos do .env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 3. BUILD, DIST E SAÍDAS DE COMPILAÇÃO
# ==========================================
# Pastas geradas pelo processo de build do TypeScript
dist/
build/
out/
.next/
.nuxt/

# ==========================================
# 4. LOGS E DEBUG
# ==========================================
# Registros de erros e logs gerados pelo Node/NPM/Yarn
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# 5. CONFIGURAÇÕES DE EDITORES E IDEs
# ==========================================
# Arquivos locais de configuração do VS Code e JetBrains
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# 6. ARQUIVOS DO SISTEMA OPERACIONAL
# ==========================================
# Arquivos invisíveis criados pelo macOS e Windows
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 7. PRISMA E BANCO DE DADOS LOCAL
# ==========================================
# Arquivos de banco SQLite local ou migrações temporárias (se aplicável)
*.db
*.db-journal
# Nota: As pastas prisma/migrations/ DEVEM ser enviadas ao Git!

# ==========================================
# 8. TESTES E COBERTURA DE CÓDIGO
# ==========================================
# Relatórios de cobertura gerados pelo Vitest/Jest
coverage/
.nyc_output/